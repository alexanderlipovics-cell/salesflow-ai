# =============================================================================
# SalesFlow AI - Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!
# =============================================================================

# Application
APP_NAME="SalesFlow AI"
DEBUG=false
API_V1_PREFIX="/api/v1"

# JWT Secrets - Generate with: openssl rand -hex 32
# IMPORTANT: Use different values for each environment!
JWT_SECRET_KEY="GENERATE_ME_WITH_openssl_rand_hex_32"
JWT_REFRESH_SECRET_KEY="GENERATE_ME_WITH_openssl_rand_hex_32_DIFFERENT"

# JWT Settings
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

# Rate Limiting
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# CORS - Add your frontend URLs
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173", "https://your-app.com"]'

# Cookie Settings
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_SAMESITE="lax"
