# SalesFlow AI Environment Configuration
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============= Application =============
APP_NAME=SalesFlow AI
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true  # Must be false in production

# ============= JWT Configuration =============
# Generate secrets with: openssl rand -base64 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_REFRESH_SECRET_KEY=CHANGE_ME_generate_different_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============= Password Policy =============
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_BCRYPT_ROUNDS=12

# ============= Rate Limiting =============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=100
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=300

# ============= CORS =============
# Comma-separated list of allowed origins
# In production, set to your actual domains
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ============= Database =============
DATABASE_URL=postgresql://user:password@localhost:5432/salesflow
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ============= Encryption =============
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_generate_encryption_key

# ============= Security =============
# Comma-separated list of allowed hosts
# In production, set to your actual domains
ALLOWED_HOSTS=localhost,127.0.0.1
TRUSTED_PROXIES=
SESSION_COOKIE_SECURE=false  # Must be true in production
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# ============= Logging =============
LOG_LEVEL=INFO
LOG_SANITIZE_ENABLED=true

# ============= External Services =============
# Add any external service API keys here
# OPENAI_API_KEY=sk-...
# SENDGRID_API_KEY=SG...


# ============= PRODUCTION CHECKLIST =============
# Before deploying to production, ensure:
# [ ] ENVIRONMENT=production
# [ ] DEBUG=false
# [ ] All *_SECRET_KEY values are unique, random 32+ byte strings
# [ ] CORS_ALLOWED_ORIGINS contains only your actual domains
# [ ] ALLOWED_HOSTS contains only your actual domains
# [ ] SESSION_COOKIE_SECURE=true
# [ ] RATE_LIMIT_ENABLED=true
# [ ] All default/example values have been replaced
